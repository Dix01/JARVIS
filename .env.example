# Copy this file to .env and fill in the values you actually use.
# JARVIS_LOCAL reads the env var name listed in config.yaml -> model.api_key_env.

# --- LLM keys (pick whichever provider you configured) ---
OLLAMA_API_KEY=
LLM_API_KEY=lm-studio
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional if you point `model.endpoint` at Google's OpenAI-compatible route.
GEMINI_API_KEY=

# --- Optional web search providers ---
BRAVE_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Optional TTS provider ---
NVIDIA_API_KEY=

# --- Optional agent CLI delegation ---
# auto, claude, codex, or opencode
JARVIS_AGENT_BACKEND=auto

# --- Optional integrations ---
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Behavior toggles ---
JARVIS_LOG_LEVEL=INFO
JARVIS_DEBUG=0
